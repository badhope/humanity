    {"id": "mbti-exp-26", "text": "您注重：", "type": "single-choice", "dimension": "TF", "options": [{"id": "A", "text": "公正和公平", "value": 3}, {"id": "B", "text": "效率和成果", "value": 1}, {"id": "C", "text": "和谐与平衡", "value": -1}, {"id": "D", "text": "关爱和支持", "value": -3}]},
