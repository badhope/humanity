    {"id": "mbti-exp-32", "text": "您更习惯于：", "type": "single-choice", "dimension": "JP", "options": [{"id": "A", "text": "把事情提前安排好", "value": 3}, {"id": "B", "text": "做一个大致的计划", "value": 1}, {"id": "C", "text": "让事情自然发生", "value": -1}, {"id": "D", "text": "随时根据情况调整", "value": -3}]},
