    {"id": "mbti-std-12", "text": "在争论中，您更关注：", "type": "single-choice", "dimension": "TF", "options": [{"id": "A", "text": "事实和逻辑是否正确", "value": 3}, {"id": "B", "text": "双方的立场是否合理", "value": 1}, {"id": "C", "text": "对方的感受是否被尊重", "value": -1}, {"id": "D", "text": "如何维护双方的关系", "value": -3}]},
