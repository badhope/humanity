    {"id": "ENTP", "name": "辩论家", "description": "您是一位充满创意和好奇心的思想者，喜欢智识的碰撞和新鲜挑战。您善于发现可能性，思维敏捷，是天然的辩论家。作为辩论家型，您善于启发他人思考，是创新的推动者。", "conditions": [{"dimension": "EI", "operator": "gt", "value": 0}, {"dimension": "SN", "operator": "gt", "value": 0}, {"dimension": "TF", "operator": "gt", "value": 0}, {"dimension": "JP", "operator": "lt", "value": 0}], "tags": ["创意", "好奇", "辩论", "创新"], "strengths": ["思维敏捷", "创造力强", "善于辩论", "适应力强", "多才多艺"], "weaknesses": ["可能缺乏专注", "三分钟热度", "喜欢抬杠"], "careers": ["营销策划", "创业者", "律师", "公关专家", "投资人"], "relationships": "您在关系中喜欢智识碰撞和新鲜感。请记得在追逐可能性时珍惜已建立的情感联系。", "growth": "建议您学会专注和坚持，尊重他人的感受和意见，在追求目标时不要伤害他人。"},
    {"id": "INFJ", "name": "提倡者", "description": "您是一位理想主义且富有同理心的人。您有强烈的价值观，追求有意义的生活，渴望帮助他人成为更好的自己。您安静而坚定，是他人的精神导师。作为提倡者型，您是理想与行动的桥梁。", "conditions": [{"dimension": "EI", "operator": "lt", "value": 0}, {"dimension": "SN", "operator": "gt", "value": 0}, {"dimension": "TF", "operator": "lt", "value": 0}, {"dimension": "JP", "operator": "gt", "value": 0}], "tags": ["理想", "同理心", "创意", "坚持"], "strengths": ["理想主义", "有同理心", "洞察力强", "创造力强", "坚守原则"], "weaknesses": ["过度完美主义", "敏感脆弱", "不切实际"], "careers": ["心理咨询师", "作家", "人力资源经理", "社工", "教师"], "relationships": "您在关系中追求深度的精神连接。请学会照顾自己的需求，而不仅是他人的期望。", "growth": "建议您设定健康的边界，接受不完美，允许自己也有软弱的时候。"},
    {"id": "INFP", "name": "调停者", "description": "您是一位温柔而有理想的梦想家。您重视真实的情感，追求内心的和谐，善于理解他人的立场。您安静而内敛，但内心世界丰富多彩。作为调停者型，您是创意的艺术家和心灵的治愈者。", "conditions": [{"dimension": "EI", "operator": "lt", "value": 0}, {"dimension": "SN", "operator": "gt", "value": 0}, {"dimension": "TF", "operator": "lt", "value": 0}, {"dimension": "JP", "operator": "lt", "value": 0}], "tags": ["理想", "同理心", "创意", "敏感"], "strengths": ["富有同理心", "创意丰富", "理想主义", "适应力强", "善于沟通"], "weaknesses": ["过度理想化", "情绪波动", "不善于冲突"], "careers": ["作家", "艺术家", "心理咨询师", "教师", "社会工作者"], "relationships": "您在关系中重视情感的真实和深度。请勇敢表达自己的需求和边界。", "growth": "建议您学会面对冲突，设定优先级，将理想付诸实践而不是只停留在想象。"},
