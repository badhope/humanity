  "questions": [
    {"id": "mbti-std-1", "text": "在社交场合中，您通常会：", "type": "single-choice", "dimension": "EI", "options": [{"id": "A", "text": "主动与陌生人交谈，享受社交的乐趣", "value": 3}, {"id": "B", "text": "与熟悉的人聊天，对陌生人保持距离", "value": 1}, {"id": "C", "text": "观察别人，等待别人来接近", "value": -1}, {"id": "D", "text": "一个人安静地待着，享受独处", "value": -3}]},
    {"id": "mbti-std-2", "text": "周末时光您更喜欢：", "type": "single-choice", "dimension": "EI", "options": [{"id": "A", "text": "约朋友一起出去玩，参加聚会", "value": 3}, {"id": "B", "text": "和几个好朋友小聚", "value": 1}, {"id": "C", "text": "在家看书或看电影", "value": -1}, {"id": "D", "text": "独自去户外探索或旅行", "value": -3}]},
    {"id": "mbti-std-3", "text": "当您独自一人时，您会感到：", "type": "single-choice", "dimension": "EI", "options": [{"id": "A", "text": "有些不自在，需要找人交流", "value": -3}, {"id": "B", "text": "有点无聊，但能接受", "value": -1}, {"id": "C", "text": "享受独处的宁静时光", "value": 1}, {"id": "D", "text": "非常充实，可以深度思考", "value": 3}]},
    {"id": "mbti-std-4", "text": "您更喜欢什么样的工作环境：", "type": "single-choice", "dimension": "EI", "options": [{"id": "A", "text": "开放式的办公室，方便交流", "value": 3}, {"id": "B", "text": "半开放半独立的空间", "value": 1}, {"id": "C", "text": "相对安静但不完全隔离", "value": -1}, {"id": "D", "text": "独立办公室或远程工作", "value": -3}]},
    {"id": "mbti-std-5", "text": "您更关注事物的：", "type": "single-choice", "dimension": "SN", "options": [{"id": "A", "text": "具体的事实和数据", "value": -3}, {"id": "B", "text": "实际可行的方案", "value": -1}, {"id": "C", "text": "未来的可能性和趋势", "value": 1}, {"id": "D", "text": "抽象的概念和深层含义", "value": 3}]},
    {"id": "mbti-std-6", "text": "阅读小说时，您更看重：", "type": "single-choice", "dimension": "SN", "options": [{"id": "A", "text": "扣人心弦的故事情节", "value": -1}, {"id": "B", "text": "生动真实的人物描写", "value": -1}, {"id": "C", "text": "深刻的人生哲理和寓意", "value": 1}, {"id": "D", "text": "作者独特的写作风格和创新表达", "value": 3}]},
    {"id": "mbti-std-7", "text": "当您学习新东西时，您会：", "type": "single-choice", "dimension": "SN", "options": [{"id": "A", "text": "看详细的教程和步骤说明", "value": -3}, {"id": "B", "text": "边做边学，遇到问题再查资料", "value": -1}, {"id": "C", "text": "先了解整体框架和原理", "value": 1}, {"id": "D", "text": "探索多种方法，找到最适合自己的", "value": 3}]},
    {"id": "mbti-std-8", "text": "您更倾向于相信：", "type": "single-choice", "dimension": "SN", "options": [{"id": "A", "text": "实际的经验和验证过的事实", "value": -3}, {"id": "B", "text": "自己的感官感受和亲身经历", "value": -1}, {"id": "C", "text": "灵感和直觉的指引", "value": 1}, {"id": "D", "text": "抽象的理论和可能性", "value": 3}]},
    {"id": "mbti-std-9", "text": "您描述事情的方式通常是：", "type": "single-choice", "dimension": "SN", "options": [{"id": "A", "text": "具体详细的描述", "value": -3}, {"id": "B", "text": "结合实际情况的分析", "value": -1}, {"id": "C", "text": "概括性的总结和推断", "value": 1}, {"id": "D", "text": "充满想象和比喻的表达", "value": 3}]},
