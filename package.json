    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@react-three/drei": "^9.97.0",
    "@react-three/fiber": "^8.15.16",
    "chart.js": "^4.4.1",
    "clsx": "^2.1.0",
    "d3": "^7.8.5",
    "dexie": "^3.2.5",
